<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Nền biển: gradient xanh dương, bo tròn 2 góc dưới -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E3A8A"
                android:centerColor="#2563EB"
                android:endColor="#38BDF8"
                android:angle="270" />

            <corners
                android:bottomLeftRadius="40dp"
                android:bottomRightRadius="40dp" />
        </shape>
    </item>

    <!-- Lớp sương nhẹ cho mềm màu, bớt đậm -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1F2937" />
            <corners
                android:bottomLeftRadius="40dp"
                android:bottomRightRadius="40dp" />
        </shape>
    </item>

    <!-- Sóng xa (xanh lam nhạt, rất thấp) -->
    <item
        android:left="-60dp"
        android:right="-60dp"
        android:top="170dp">
        <shape android:shape="rectangle">
            <solid android:color="#3348C7F3" />
            <corners
                android:topLeftRadius="130dp"
                android:topRightRadius="130dp" />
        </shape>
    </item>

    <!-- Sóng giữa (xanh ngọc) -->
    <item
        android:left="-40dp"
        android:right="-40dp"
        android:top="190dp">
        <shape android:shape="rectangle">
            <solid android:color="#5538BDF8" />
            <corners
                android:topLeftRadius="140dp"
                android:topRightRadius="140dp" />
        </shape>
    </item>

    <!-- Sóng gần (trắng, sát mép content, không che avatar) -->
    <item
        android:left="-40dp"
        android:right="-40dp"
        android:top="210dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners
                android:topLeftRadius="150dp"
                android:topRightRadius="150dp" />
        </shape>
    </item>

    <!-- Bọt sóng mờ, rất nhẹ -->
    <item
        android:left="50dp"
        android:top="205dp">
        <shape android:shape="oval">
            <size
                android:width="70dp"
                android:height="70dp" />
            <solid android:color="#14FFFFFF" />
        </shape>
    </item>

    <item
        android:right="40dp"
        android:top="135dp">
        <shape android:shape="oval">
            <size
                android:width="60dp"
                android:height="60dp" />
            <solid android:color="#0FFFFFFF" />
        </shape>
    </item>

</layer-list>