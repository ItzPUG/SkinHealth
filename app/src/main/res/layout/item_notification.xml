<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNotice"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/bg_icon_soft_blue"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imgUnreadDot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_unread_dot_blue" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNoticeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đến hạn tái quét"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNoticeMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hồ sơ A • Cần theo dõi"
                android:textColor="#334155"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtNoticeDueAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Đến hạn: 30/03/2026 10:00"
                android:textColor="#64748B"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_icon_soft_blue"
            android:padding="6dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_arrow_right"
                app:tint="#5C73E7" />
        </FrameLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
