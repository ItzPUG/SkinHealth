<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2563EB"
    tools:context=".HistoryDetailActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@android:color/transparent"
        android:paddingHorizontal="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white"
        app:title="Chi tiết kết quả"
        app:titleTextColor="@android:color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardMainDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#F8FBFF"
        app:cardCornerRadius="30dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDetail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStickySummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EEF7FF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#D9E6FF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtStickyStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_white_pill"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="Đang đánh giá"
                            android:textColor="#1D4ED8"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtStickyTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Tóm tắt kết quả hiện tại"
                            android:textColor="#0F172A"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtStickySub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Hành động ưu tiên sẽ hiển thị tại đây"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrimaryAction"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="10dp"
                        android:text="Hành động"
                        android:visibility="gone"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#2563EB"
                        app:cornerRadius="20dp" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPrediction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#EEF7FF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#D9E6FF"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="68dp"
                                    android:layout_height="68dp"
                                    app:cardBackgroundColor="@android:color/white"
                                    app:cardCornerRadius="17dp"
                                    app:cardElevation="0dp">

                                    <ImageView
                                        android:id="@+id/imgResult"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_camera" />
                                </androidx.cardview.widget.CardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <!-- Giữ ID để code Java hiện tại không lỗi -->
                                    <TextView
                                        android:id="@+id/txtRiskTag"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:visibility="gone" />

                                    <!-- Tự co chữ để mọi mức nguy cơ luôn nằm trên một dòng -->
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:id="@+id/txtResultDetail"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:includeFontPadding="false"
                                        android:maxLines="1"
                                        android:singleLine="true"
                                        android:text="Nguy cơ trung bình"
                                        android:textColor="#C2410C"
                                        android:textStyle="bold"
                                        app:autoSizeMaxTextSize="29sp"
                                        app:autoSizeMinTextSize="13sp"
                                        app:autoSizeStepGranularity="1sp"
                                        app:autoSizeTextType="uniform" />

                                    <!-- Hàng dưới: mô tả bên trái, phần trăm bên phải -->
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/txtResultSub"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:ellipsize="end"
                                            android:maxLines="2"
                                            android:text="Tiếp tục theo dõi tại nhà"
                                            android:textColor="#64748B"
                                            android:textSize="13sp" />

                                        <TextView
                                            android:id="@+id/txtPercentCircle"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:includeFontPadding="false"
                                            android:text="85.77%"
                                            android:textColor="#3150C7"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/txtConfidenceLevel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Mức chắc chắn: Cao"
                                android:textColor="#3150C7"
                                android:visibility="gone"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtDateDetail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="16/03/2026 13:09"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Diễn giải kết quả"
                                android:textColor="#111827"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtConfidenceDetail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Độ tin cậy mô hình: 85.77%"
                                android:textColor="#1F2937"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtRiskExplain"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="Kết quả AI cho thấy tổn thương thuộc nhóm nguy cơ thấp."
                                android:textColor="#4B5563"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtNextAction"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_quick_card"
                                android:padding="12dp"
                                android:text="Khuyến nghị tiếp theo"
                                android:textColor="#334155"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Diễn tiến theo thời gian"
                                android:textColor="#111827"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtTimelineStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_white_pill"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="Đang cập nhật diễn tiến"
                                android:textColor="#1D4ED8"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtTimelineSummary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:text="Hệ thống sẽ tổng hợp xu hướng giữa các lần quét cùng hồ sơ."
                                android:textColor="#334155"
                                android:textSize="13sp" />

                            <LinearLayout
                                android:id="@+id/layoutTimelineNodes"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="vertical" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:paddingHorizontal="16dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCompareNearest"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:text="So sánh lần gần nhất"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#2563EB"
                                    app:cornerRadius="12dp"
                                    app:iconGravity="textStart"
                                    app:iconPadding="4dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCompareScan"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="So sánh nâng cao"
                                    android:textAllCaps="false"
                                    android:textColor="#2563EB"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    app:strokeColor="#2563EB"
                                    app:strokeWidth="1.5dp"
                                    app:cornerRadius="12dp"
                                    app:rippleColor="#D1E9FF" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Theo dõi cá nhân"
                                android:textColor="#111827"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtNoteValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Chưa có ghi chú cho lần quét này."
                                android:textColor="#4B5563"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtReminderValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Chưa bật nhắc tái quét."
                                android:textColor="#4B5563"
                                android:textSize="13sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingHorizontal="16dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnEditNote"
                                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:includeFontPadding="false"
                                    android:maxLines="1"
                                    android:minWidth="0dp"
                                    android:text="Ghi chú"
                                    android:textAlignment="center"
                                    android:textAllCaps="false"
                                    android:textColor="#2563EB"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#EFF6FF"
                                    app:cornerRadius="12dp"
                                    app:rippleColor="#DBEAFE" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSetReminder"
                                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:includeFontPadding="false"
                                    android:lineSpacingExtra="0dp"
                                    android:maxLines="2"
                                    android:minWidth="0dp"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:text="Nhắc tái&#10;kiểm tra"
                                    android:textAlignment="center"
                                    android:textAllCaps="false"
                                    android:textColor="#2563EB"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#EFF6FF"
                                    app:cornerRadius="12dp"
                                    app:icon="@drawable/ic_alarm"
                                    app:iconGravity="end"
                                    app:iconPadding="0dp"
                                    app:iconSize="16dp"
                                    app:iconTint="#2563EB"
                                    app:rippleColor="#DBEAFE" />

                            </LinearLayout>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFollowUpScan"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="12dp"
                                android:layout_marginHorizontal="16dp"
                                android:text="Tái kiểm tra"
                                android:textAllCaps="false"
                                android:textColor="#2563EB"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:strokeColor="#2563EB"
                                app:strokeWidth="1.5dp"
                                app:cornerRadius="12dp"
                                app:iconGravity="textStart"
                                app:iconTint="#2563EB"
                                app:rippleColor="#D1E9FF" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAttachCase"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="12dp"
                                android:layout_marginHorizontal="16dp"
                                android:text="Gán vào hồ sơ để theo dõi"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:backgroundTint="#2563EB"
                                app:cornerRadius="12dp"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp"
                                app:elevation="2dp" />

                            <TextView
                                android:id="@+id/txtToggleDetails"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Xem thêm thông tin kỹ thuật"
                                android:textColor="#3150C7"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtDetailInfo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:lineSpacingExtra="3dp"
                                android:textColor="#64748B"
                                android:textSize="12sp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="SkinHealth app v1"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
