<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="172dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="172dp"
        android:layout_height="118dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgScan"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_scan_rounded"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_camera" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#2B0F172A" />

            <TextView
                android:id="@+id/txtScanType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_glass_box"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Mới"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtScanName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="1"
        android:text="Hồ sơ bệnh nhân"
        android:textColor="#0F172A"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtScanResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:background="@drawable/bg_icon_soft_blue"
        android:paddingStart="10dp"
        android:paddingTop="1dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="Lành tính"
        android:textColor="#1D4ED8"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtScanDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:text="16/04/2026 • 09:20 • 92%"
        android:textColor="#64748B"
        android:textSize="12sp" />

</LinearLayout>
